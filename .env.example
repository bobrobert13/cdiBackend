# Node environment
NODE_ENV=development

# Server port
PORT=4000

# Apollo Studio
APOLLO_KEY=your_apollo_key_here
APOLLO_GRAPH_REF=your_graph_ref
APOLLO_SCHEMA_REPORTING=false

# Database (if using environment variables)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cdi_database
DB_USER=root
DB_PASS=123456

# JWT Secret (optional)
JWT_SECRET=your_jwt_secret_here